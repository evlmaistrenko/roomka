{
  "name": "roomka",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/evlmaistrenko/roomka#readme",
  "bugs": {
    "url": "https://github.com/evlmaistrenko/roomka/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evlmaistrenko/roomka.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:broadcast": "dotenv -e .env -- go -C apps/broadcast tool air",
    "dev:graphql": "dotenv -e .env -- npm run dev -w apps/graphql",
    "dev:ui": "dotenv -e .env -- npm run dev -w apps/ui",
    "dev": "concurrently npm:dev:*",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0"
  },
  "workspaces": [
    "apps/graphql",
    "apps/ui"
  ]
}
