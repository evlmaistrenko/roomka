{
	"name": "roomka",
	"version": "0.2.1",
	"private": true,
	"homepage": "https://github.com/evlmaistrenko/roomka#readme",
	"bugs": {
		"url": "https://github.com/evlmaistrenko/roomka/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evlmaistrenko/roomka.git"
	},
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev:broadcast": "dotenv -e .env -- go -C services/broadcast tool air",
		"dev:ui": "dotenv -e .env -- npm run dev -w services/ui",
		"dev": "concurrently npm:dev:*",
		"test:broadcast": "dotenv -e .env -- go -C services/broadcast test ./...",
		"test": "concurrently npm:test:*",
		"prepare": "husky"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@trivago/prettier-plugin-sort-imports": "^4.3.0",
		"concurrently": "^10.0.3",
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "3.4.2",
		"prettier-plugin-jsdoc": "^1.8.1"
	},
	"workspaces": ["services/ui"]
}
