# WebTransport TLS cert. One of:
#   ephemeral                          self-signed, browser pins the hash
#   static:/path/to/cert;/path/to/key  real cert + key pair
ROOMKA_WEB_TRANSPORT_CERT=ephemeral

# HMAC secret for the access token. Use a strong random one in prod.
ROOMKA_ACCESS_SECRET=roomka-dev-access-secret-change-me

# Host the UI connects to and Caddy serves.
ROOMKA_HOSTNAME=localhost

# WebTransport UDP/QUIC port.
ROOMKA_WEB_TRANSPORT_PORT=4433

# broadcast HTTP API port (/api/*).
ROOMKA_API_PORT=8080

# Used when running from the image.
ROOMKA_ACME_EMAIL=
