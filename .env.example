# Roomka monorepo environment (development).
#
# Copy to .env (gitignored) and adjust:  cp .env.example .env
# The dev scripts load this file and inject the variables into each app's
# process. In production the container runtime sets these directly; there is no
# .env there.
#
# Variables are namespaced per app: ROOMKA_BROADCAST_*, ROOMKA_GRAPHQL_*,
# ROOMKA_UI_*, ...

# --- broadcast (WebTransport relay) ---
# UDP/QUIC port for WebTransport (bound on all interfaces).
ROOMKA_BROADCAST_PORT=4433
# HTTP route the WebTransport CONNECT upgrade is mounted on.
ROOMKA_BROADCAST_ROUTE=/
# Production TLS: PEM certificate + key files. Leave both empty for dev mode
# (ephemeral self-signed certificate regenerated on each start).
ROOMKA_BROADCAST_CERT_PATH=
ROOMKA_BROADCAST_CERT_KEY_PATH=
# Dev mode only: plain-HTTP port serving the certificate hash at /cert-hash.
ROOMKA_BROADCAST_DEV_CERT_HASH_PORT=8080
# HMAC secret used to verify the JWT that authorizes each connection. This dev
# value is a placeholder (like the self-signed cert) — set a strong random
# secret in production, and sign clients' tokens with the same value.
ROOMKA_BROADCAST_JWT_SECRET=roomka-dev-jwt-secret-change-in-production

# --- graphql ---
# (no parameters yet)

# --- ui ---
# (no parameters yet)
